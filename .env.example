# LLM_BACKEND=openai/gemini/deepseek/huggingface

# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5-nano-2025-08-07
# OPENAI_TEMPERATURE=0.0

# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TEMPERATURE=0.0

# Deepseek_API_KEY=your_deepseek_api_key_here
# Deepseek_MODEL=deepseek-chat
# Deepseek_TEMPERATURE=0.0

# HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# HF_DEVICE=auto
# HF_MAX_TOKENS=512
# HF_LOAD_IN_4BIT=false              # only set to true if you have GPU and want to save VRAM, but it may reduce performance
# # HF_TOKEN=your-huggingface-token  # only needed for gated models (Llama, Gemma)


