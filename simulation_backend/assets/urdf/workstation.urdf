<?xml version="1.0"?>
<!--
workstation.urdf
----------------
Industrial workstation — a raised platform with four legs and a work surface.
Used as the "workstation" object in the simulation workspace.

Dimensions (metres):
    Surface:    0.40 wide (X) x 0.30 deep (Y) x 0.02 thick (Z)
    Legs:       0.03 x 0.03 cross-section, 0.30 tall
    Total height from origin to surface top: 0.32m

Origin is at the centre of the workstation base (floor level).
Place in scene_config.yaml at z=0.0 so legs sit on the table surface.

Mass = 0.0 — static object, fixed to table surface.
Colour is applied at runtime via changeVisualShape() in object_loader.py.
The default dark grey colour here is just a placeholder.

Structure:
    - 1 work surface (top platform)
    - 4 legs (one at each corner)
    - 1 lower shelf (mid-level storage, optional visual detail)
-->

<robot name="workstation">

  <link name="base_link">

    <!-- ── Work surface (top platform) ──────────────────────────────── -->
    <visual>
      <origin xyz="0.0 0.0 0.310"/>
      <geometry>
        <box size="0.40 0.30 0.020"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.35 0.35 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.310"/>
      <geometry>
        <box size="0.40 0.30 0.020"/>
      </geometry>
    </collision>

    <!-- ── Front-left leg ────────────────────────────────────────────── -->
    <visual>
      <origin xyz="-0.175 0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.35 0.35 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.175 0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
    </collision>

    <!-- ── Front-right leg ───────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.175 0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.35 0.35 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.175 0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
    </collision>

    <!-- ── Back-left leg ─────────────────────────────────────────────── -->
    <visual>
      <origin xyz="-0.175 -0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.35 0.35 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.175 -0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
    </collision>

    <!-- ── Back-right leg ────────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.175 -0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.35 0.35 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.175 -0.125 0.150"/>
      <geometry>
        <box size="0.030 0.030 0.300"/>
      </geometry>
    </collision>

    <!-- ── Lower shelf (mid-level) ───────────────────────────────────── -->
    <visual>
      <origin xyz="0.0 0.0 0.150"/>
      <geometry>
        <box size="0.34 0.24 0.015"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.35 0.35 0.35 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.150"/>
      <geometry>
        <box size="0.34 0.24 0.015"/>
      </geometry>
    </collision>

    <!-- ── Inertial — static object, mass = 0 ────────────────────────── -->
    <inertial>
      <origin xyz="0.0 0.0 0.0"/>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0"
               iyy="0.0" iyz="0.0"
               izz="0.0"/>
    </inertial>

  </link>

</robot>
