<?xml version="1.0"?>
<!--
table.urdf
----------
Workspace table surface for the simulation environment.
A flat rectangular platform that all scene objects rest on.

Dimensions (metres):
    Surface:    2.00 wide (X) x 1.50 deep (Y) x 0.05 thick (Z)
    Legs:       0.05 x 0.05 cross-section, 0.70 tall

Origin is at the centre of the table top surface.
Place at z=0.0 in world coordinates — the table top sits at z=0,
objects placed at z > 0 rest on the surface.

Mass = 0.0 — static object, fixed to world.
Uses primitive box geometry only — no mesh files required.
-->

<robot name="table">

  <link name="base_link">

    <!-- ── Table top surface ─────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.0 0.0 -0.025"/>
      <geometry>
        <box size="2.00 1.50 0.050"/>
      </geometry>
      <material name="wood">
        <color rgba="0.76 0.60 0.42 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 -0.025"/>
      <geometry>
        <box size="2.00 1.50 0.050"/>
      </geometry>
    </collision>

    <!-- ── Front-left leg ────────────────────────────────────────────── -->
    <visual>
      <origin xyz="-0.95 0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
      <material name="wood">
        <color rgba="0.76 0.60 0.42 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.95 0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
    </collision>

    <!-- ── Front-right leg ───────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.95 0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
      <material name="wood">
        <color rgba="0.76 0.60 0.42 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.95 0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
    </collision>

    <!-- ── Back-left leg ─────────────────────────────────────────────── -->
    <visual>
      <origin xyz="-0.95 -0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
      <material name="wood">
        <color rgba="0.76 0.60 0.42 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.95 -0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
    </collision>

    <!-- ── Back-right leg ────────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.95 -0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
      <material name="wood">
        <color rgba="0.76 0.60 0.42 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.95 -0.70 -0.375"/>
      <geometry>
        <box size="0.05 0.05 0.700"/>
      </geometry>
    </collision>

    <!-- ── Inertial — static object, mass = 0 ────────────────────────── -->
    <inertial>
      <origin xyz="0.0 0.0 0.0"/>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0"
               iyy="0.0" iyz="0.0"
               izz="0.0"/>
    </inertial>

  </link>

</robot>
