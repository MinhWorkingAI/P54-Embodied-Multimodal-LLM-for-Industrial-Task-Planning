<?xml version="1.0"?>
<!--
tray.urdf
---------
Industrial placement tray with a flat base and four low walls.
Used as "left tray" and "right tray" in the simulation workspace.

Dimensions (metres):
    Base:   0.20 wide (X) x 0.15 deep (Y) x 0.01 thick (Z)
    Walls:  0.01 thick, 0.04 tall above the base surface
    Total height from origin: 0.05m

Origin is at the centre of the base plate bottom surface.
Place in scene_config.yaml at z=0.0 so base sits flush on the table.

Mass = 0.0 — static object, fixed to table surface.
Colour is applied at runtime via changeVisualShape() in object_loader.py.
The default grey colour here is just a placeholder.
-->

<robot name="tray">

  <link name="base_link">

    <!-- ── Base plate ────────────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.0 0.0 0.005"/>
      <geometry>
        <box size="0.20 0.15 0.010"/>
      </geometry>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.005"/>
      <geometry>
        <box size="0.20 0.15 0.010"/>
      </geometry>
    </collision>

    <!-- ── Front wall (+Y) ───────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.0 0.070 0.030"/>
      <geometry>
        <box size="0.20 0.010 0.040"/>
      </geometry>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.070 0.030"/>
      <geometry>
        <box size="0.20 0.010 0.040"/>
      </geometry>
    </collision>

    <!-- ── Back wall (-Y) ────────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.0 -0.070 0.030"/>
      <geometry>
        <box size="0.20 0.010 0.040"/>
      </geometry>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 -0.070 0.030"/>
      <geometry>
        <box size="0.20 0.010 0.040"/>
      </geometry>
    </collision>

    <!-- ── Left wall (-X) ────────────────────────────────────────────── -->
    <visual>
      <origin xyz="-0.095 0.0 0.030"/>
      <geometry>
        <box size="0.010 0.15 0.040"/>
      </geometry>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.095 0.0 0.030"/>
      <geometry>
        <box size="0.010 0.15 0.040"/>
      </geometry>
    </collision>

    <!-- ── Right wall (+X) ───────────────────────────────────────────── -->
    <visual>
      <origin xyz="0.095 0.0 0.030"/>
      <geometry>
        <box size="0.010 0.15 0.040"/>
      </geometry>
      <material name="grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.095 0.0 0.030"/>
      <geometry>
        <box size="0.010 0.15 0.040"/>
      </geometry>
    </collision>

    <!-- ── Inertial — static object, mass = 0 ────────────────────────── -->
    <inertial>
      <origin xyz="0.0 0.0 0.0"/>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0"
               iyy="0.0" iyz="0.0"
               izz="0.0"/>
    </inertial>

  </link>

</robot>
